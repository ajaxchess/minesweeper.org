# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=minesweeper
DB_USER=minesweeper_user
DB_PASS=your_database_password

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://yourdomain.com/auth/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Session security ──────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_key_here

# ── Google Analytics (optional) ───────────────────────────────────────────────
GA_TAG=G-XXXXXXXXXX

# ── Twitter / X (optional) ────────────────────────────────────────────────────
# Handle without the @ — used for twitter:site meta tag on all pages.
# e.g. for https://x.com/minesweeper_org set:
TWITTER_HANDLE=minesweeper_org

# ── Admin users ───────────────────────────────────────────────────────────────
# Comma-separated list of Google account emails that can access /admin
ADMIN_EMAILS=you@example.com

# ── Environment ───────────────────────────────────────────────────────────────
# Identifies the running environment: dev | staging | prod
#   dev     → localhost
#   staging → dev.minesweeper.org
#   prod    → minesweeper.org
ENVIRONMENT=dev

# ── AWS ───────────────────────────────────────────────────────────────────────
# EC2 instance ID — used for AWS scripting and infrastructure automation
AWS_EC2_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx

# ── OpenTelemetry — AWS Bedrock observability ─────────────────────────────────
# Leave OTEL_EXPORTER_OTLP_ENDPOINT unset (or blank) to disable tracing entirely.
# Point it at the AWS Distro for OpenTelemetry (ADOT) Collector to forward
# traces to X-Ray and metrics to CloudWatch for Bedrock to consume.
#
# Example (ADOT Collector running locally on port 4318):
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
#
OTEL_SERVICE_NAME=minesweeper.org
OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=x-api-key=your_key
